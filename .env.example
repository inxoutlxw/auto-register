# Auto Register 环境变量示例

# ============================================================
# 1. 核心运行设置
# ============================================================
# 临时邮箱提供者（mailtm / 1secmail）
AUTO_REGISTER_EMAIL_PROVIDER=mailtm

# 目标站点（对应 config/ 下的 yaml 文件名，默认 qwen）
TARGET_SITE=qwen

# 邮箱轮询配置
AUTO_REGISTER_EMAIL_TIMEOUT=120
AUTO_REGISTER_POLL_INTERVAL=5

# 是否启用无头浏览器（默认 false，由 cli 的 --headless 控制）
# ENABLE_HEADLESS=false

# 浏览器防机器人检测（可选，防止被识破为爬虫）
USE_PLAYWRIGHT_STEALTH=true

# 真实的 HTTP / SOCKS 代理地址（可选，如 http://ip:port，解决 IP 被拉黑）
# HTTP_PROXY_URL=http://your_proxy_ip:port

# token 统一保存根目录（可选，覆盖 yaml 中的 ./token 定义）
# SAVE_DIR=./token


# ============================================================
# 2. 密码生成策略（全局）
# ============================================================
PASSWORD_LENGTH=14
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGITS=true


# ============================================================
# 3. 超时设置（毫秒，全局默认值）
# ============================================================
TIMEOUT_NAVIGATION_MS=30000             # 页面导航超时
TIMEOUT_ELEMENT_VISIBLE_MS=10000        # 等待元素可见
TIMEOUT_ELEMENT_SHORT_MS=5000           # 短等待（如按钮出现）
TIMEOUT_PAGE_LOAD_MS=2000               # 页面加载后等待
TIMEOUT_POST_ACTIVATION_MS=3000         # 激活后等待
TIMEOUT_POST_LOGIN_MS=5000              # 登录后等待
TIMEOUT_PRE_TOKEN_MS=3000               # 提取 token 前等待
TIMEOUT_NETWORKIDLE_MS=15000            # 等待网络空闲
TIMEOUT_SUBMIT_READY_MS=10000           # 等待提交按钮就绪
TIMEOUT_OAUTH_CODE_INPUT_MS=2000        # 设备码输入框等待
TIMEOUT_OAUTH_APPROVE_BTN_MS=3000       # 同意按钮等待
TIMEOUT_POST_APPROVE_MS=2000            # 点击同意后等待
